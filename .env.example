# PostgreSQL
POSTGRES_USER=procompta
POSTGRES_PASSWORD=changeme
POSTGRES_DB=procompta
POSTGRES_HOST=db
POSTGRES_PORT=5432

# API
API_PORT=8001
DATABASE_URL=postgresql+asyncpg://procompta:changeme@db:5432/procompta

# Storage - chemin local (Docker override: STORAGE_PATH=/app/storage dans docker-compose)
STORAGE_PATH=/absolute/path/to/ProCompta/storage

# Auth
SECRET_KEY=change-me-in-production
ADMIN_NAME=Antonin
ADMIN_EMAIL=admin@procompta.local
ADMIN_PASSWORD=changeme

# Gmail OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# sauvegardé automatiquement après auth
GMAIL_REFRESH_TOKEN=                                                                                                                             

# SMTP pour les rappels email                                                                                                                                                                    
SMTP_HOST=smtp.gmail.com               
SMTP_PORT=587                                                                                                                                                                                    
SMTP_USER=user@gmail.com                
# App password gmail
SMTP_PASSWORD=